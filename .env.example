# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# MongoDB Connection String (MongoDB Atlas recommended)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/footballbot?retryWrites=true&w=majority

# Football Data API Key from https://www.football-data.org/
FOOTBALL_API_KEY=your_api_key_here

# Comma separated Telegram User IDs who are admins (get from @userinfobot or bot logs)
ADMIN_USER_IDS=123456789,987654321

# Default starting coins for new users
DEFAULT_STARTING_COINS=1000

# Payment instructions for manual deposits (edit as needed)
PAYMENT_METHOD=bKash / Nagad
PAYMENT_NUMBER=01XXXXXXXXX
PAYMENT_INSTRUCTIONS=Send the exact amount to the number above. Then use /txid command with your transaction ID.

# Minimum deposit amount in coins (1:1 with real money, e.g. 100 coins = 100 BDT)
MIN_DEPOSIT=100

# Public URL for webhook mode (set on Render/Railway as RENDER_EXTERNAL_URL or PUBLIC_URL)
PUBLIC_URL=https://your-app.onrender.com

# Bot name for messages
BOT_NAME=Football Coin Predictor

# Cron interval for settling bets in minutes
SETTLE_INTERVAL_MINUTES=10

# Port for server (Render/Railway will set PORT)
PORT=3000

# Admin panel login credentials
ADMIN_EMAIL=mdswampodsarkar@gmail.com
ADMIN_PASS=123456

# Secret token for HTML admin panel (change this!)
ADMIN_API_TOKEN=supersecretadmintoken123changeit

# Firebase Realtime Database (instead of MongoDB)
FIREBASE_DATABASE_URL=https://gen-z-airdrop-default-rtdb.asia-southeast1.firebasedatabase.app

# Option A: Base64 of serviceAccountKey.json (recommended for hosting)
# FIREBASE_SERVICE_ACCOUNT_BASE64= (paste base64 here)

# Option B: Individual values (run without any JSON file)
FIREBASE_PROJECT_ID=gen-z-airdrop
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@gen-z-airdrop.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

